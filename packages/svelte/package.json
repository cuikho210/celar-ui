{
	"name": "@celar-ui/svelte",
	"version": "2.1.0",
	"license": "MIT",
	"author": {
		"name": "cuikho210",
		"email": "tonykms210@gmail.com",
		"url": "https://github.com/cuikho210"
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && bun run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"npm-publish": "bun run build && export $(grep -v '^#' ../../.env | xargs) && npm publish --access=public",
		"gen-theme": "bun run ./src/bin/gen-theme.ts"
	},
	"files": [
		"dist",
		"src/styles",
		"src/bin",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./styles/index.css": "./src/styles/index.css",
		"./styles/theme.css": "./src/styles/theme.css",
		"./styles/*.css": "./src/styles/*.css"
	},
	"bin": {
		"gen-theme": "./src/bin/gen-theme.ts"
	},
	"peerDependencies": {
		"bits-ui": "^2.8.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@iconify-json/hugeicons": "^1.2.25",
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/vite": "^4.2.2",
		"bits-ui": "^2.17.3",
		"csstype": "^3.2.3",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^16.5.0",
		"material-dynamic-colors": "^1.1.4",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.18",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.1",
		"unplugin-icons": "^22.5.0",
		"vite": "^6.4.2"
	},
	"keywords": [
		"svelte"
	],
	"packageManager": "bun@1.1.0"
}
